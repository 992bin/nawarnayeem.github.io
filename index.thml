<body>
  <div class="container">
    <h1>Nawar Nayeem</h1>
    <div class="subtitle">Health Economist | Psychiatric Epidemiology Researcher</div>
    <div class="affiliation">Independent Researcher</div>
    <div class="topline">
      <a href="mailto:your.email@domain.com">your.email@domain.com</a>
